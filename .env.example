# Remnawave API base URL, including /api
RW_API_URL=https://panel.example.com/api
RW_API_TOKEN=YOUR_API_TOKEN

# Backup squad UUID
BACKUP_SQUAD_UUID=backup-squad-uuid

# Temporary ACTIVE access duration in days after switching to backup squad
TEMP_ACTIVE_DAYS=3

# Temporary traffic limit in MB during the temporary ACTIVE period
TEMP_ACTIVE_TRAFFIC_LIMIT_MB=300

# Public webhook path
WEBHOOK_PATH=/api/v1/remnawave

# Port inside the container
PORT=3000

# Host interface and port for reverse proxy
BIND_HOST=127.0.0.1
HOST_PORT=3002

# State file path
DATA_PATH=/data/original_squads.json
