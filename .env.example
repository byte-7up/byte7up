# Remnawave API base URL, including /api.
# If this service runs in the same Docker network as the panel, prefer:
# RW_API_URL=http://remnawave:3000/api
RW_API_URL=https://panel.example.com/api
RW_API_TOKEN=YOUR_API_TOKEN

# Must match WEBHOOK_SECRET_HEADER from the Remnawave panel .env
WEBHOOK_SECRET_HEADER=aabbccddeeff00112233445566778899

# Backup internal squad UUIDs. Multiple UUIDs are supported with commas.
BACKUP_SQUAD_UUID=backup-squad-uuid

# Optional backup external squad UUID. Leave empty to keep external squad unchanged.
BACKUP_EXTERNAL_SQUAD_UUID=

# Temporary ACTIVE access duration in days after switching to backup squad
TEMP_ACTIVE_DAYS=3

# Temporary traffic limit in MB during the temporary ACTIVE period
TEMP_ACTIVE_TRAFFIC_LIMIT_MB=300

# Public webhook path
WEBHOOK_PATH=/api/v1/remnawave

# Replay/body protections. Set WEBHOOK_MAX_AGE_SECONDS=0 only if your panel does not send timestamps.
WEBHOOK_MAX_AGE_SECONDS=300
MAX_WEBHOOK_BODY_BYTES=1048576

# Port inside the container
PORT=3040

# Host interface and port for reverse proxy
BIND_HOST=127.0.0.1
HOST_PORT=3040

# State file path
DATA_PATH=/data/original_squads.json

# Optional reverse-proxy protections for external panel API access.
# Uncomment only what your panel reverse proxy requires.
# RW_API_CADDY_TOKEN=value-from-X-Api-Key
# RW_API_COOKIE=name=value
# RW_API_CF_CLIENT_ID=cloudflare_access_client_id
# RW_API_CF_CLIENT_SECRET=cloudflare_access_client_secret
# RW_API_INTERNAL_PROXY_HEADERS=auto
